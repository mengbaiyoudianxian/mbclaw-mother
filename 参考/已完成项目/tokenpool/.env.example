# ═══════════════════════════════════════
#  Token Pool 环境变量
#  复制为 .env 填写真实值
# ═══════════════════════════════════════

# 数据目录
TP_DATA=/var/lib/token_pool

# 服务端口
TP_HOST=0.0.0.0
TP_PORT=8100

# 管理接口鉴权（必须改！）
TP_ADMIN_KEY=changeme

# 调用者鉴权（空=不验证，MBclaw母体调用时填这个）
TP_PROXY_KEY=

# 熔断设置
TP_CB_THRESHOLD=3      # 连续失败N次开启熔断
TP_CB_COOLDOWN=60      # 熔断冷却秒数

# 健康检测
TP_HEALTH_INTERVAL=300  # 每5分钟自动检测一次
TP_HEALTH_TIMEOUT=10

# MiClaw 桥（可选）
MICLAW_API_BASE=http://100.126.55.0:8765
MICLAW_TOKEN_KEY=
