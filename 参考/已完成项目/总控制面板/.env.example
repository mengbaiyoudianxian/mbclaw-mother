# ── MBclaw 总控制面板 Production Config ──────────────────────
# 复制为 .env 后修改: cp .env.example .env

# ============================================================
# LLM 模型配置 (必填，或使用 Mock 模式)
# ============================================================

# LLM API Base URL
MBCLAW_LLM_BASE_URL=https://api.openai.com/v1

# LLM API Key
MBCLAW_LLM_API_KEY=sk-your-api-key-here

# LLM 模型名称
MBCLAW_LLM_MODEL=gpt-4o-mini

# Mock 模式: 设为 1 则不调用真实 LLM，返回模拟回复 (用于测试)
# 与真实 LLM 配置二选一: MBCLAW_LLM_MOCK=1 时不需 API Key
# MBCLAW_LLM_MOCK=1

# ============================================================
# 数据库
# ============================================================

# SQLite 数据库路径 (默认 data/mbclaw.db)
# MBCLAW_DB_PATH=data/mbclaw.db

# ============================================================
# 数据目录
# ============================================================

# 主数据目录 (心跳、配置、上传等)
# MBCLAW_DATA=/var/lib/mbclaw

# 文件上传目录
# MBCLAW_UPLOADS=/var/lib/mbclaw/uploads

# 上传 Token (管理用)
# MBCLAW_UPLOAD_TOKEN=mengbai

# ============================================================
# 外部服务集成 (可选)
# ============================================================

# GitHub (代码仓库操作)
# GITHUB_TOKEN=ghp_xxx

# SSH (远程执行)
# SSH_PASS=xxx

# QQ Bot
# QQ_BOT_APPID=1904147233
# QQ_BOT_SECRET=xxx

# OpenAI (备用 Provider)
# OPENAI_API_KEY=sk-xxx

# MiClaw Bridge
# MICLAW_BRIDGE_URL=http://127.0.0.1:8765
