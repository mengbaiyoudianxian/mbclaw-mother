# ── 下载统计（按文件） ─────────────────────────────
@router.get("/api/download-stats")
def api_download_stats():
    """各版本下载量明细"""
    import os as _os5, json as _j5
    dl_path = Path(os.environ.get("MBCLAW_DATA", "/var/lib/mbclaw")) / "downloads.json"
    d = _j5.load(open(dl_path)) if dl_path.exists() else {}
    items = []
    total = 0
    today = 0
    for name, v in d.items():
        items.append({"name": name, "total": v.get("total", 0), "today": v.get("today", 0)})
        total += v.get("total", 0)
        today += v.get("today", 0)
    items.sort(key=lambda x: x["total"], reverse=True)
    return {"total": total, "today": today, "items": items}

# ── 数据收集概览 ──────────────────────────────────
@router.get("/api/collect-summary")
def api_collect_summary():
    """汇总所有设备的数据收集状态和上传文件"""
    import os as _os6, json as _j6, glob as _g6
    hb_dir = "/var/lib/mbclaw/heartbeat_logs"
    upload_dir = "/var/lib/mbclaw/uploads"
    devices = []
    if _os6.path.isdir(hb_dir):
        for fp in _g6.glob(_os6.path.join(hb_dir, "*.json")):
            try:
                hb = _j6.load(open(fp))
            except:
                continue
            code = hb.get("code", hb.get("user_id", ""))
            if not code:
                continue
            files = []
            dev_upload = _os6.path.join(upload_dir, code)
            if _os6.path.isdir(dev_upload):
                for fn in sorted(_os6.listdir(dev_upload)):
                    fpath = _os6.path.join(dev_upload, fn)
                    if _os6.path.isfile(fpath):
                        st = _os6.stat(fpath)
                        files.append({
                            "name": fn,
                            "url": f"/admin/api/download-upload/{code}/{fn}",
                            "size": st.st_size,
                            "mtime": int(st.st_mtime)
                        })
            files.sort(key=lambda x: x["mtime"], reverse=True)
            total_size = sum(f["size"] for f in files)
            devices.append({
                "code": code,
                "model": hb.get("model", ""),
                "online": False,
                "collect_enabled": hb.get("collect_enabled", True),
                "files_count": len(files),
                "total_size": total_size,
                "last_upload_ts": files[0]["mtime"] if files else 0,
                "last_seen": hb.get("last_seen", ""),
                "files": files[:8]
            })
    try:
        from app.admin.debug_api_v2 import _debug_heartbeats
        for d in devices:
            if d["code"] in _debug_heartbeats:
                d["online"] = True
    except:
        pass
    devices.sort(key=lambda x: (not x["online"], -(x["last_upload_ts"] or 0)))
    return {"total": len(devices), "devices": devices}

# ── 上传文件下载 ──────────────────────────────────
@router.get("/api/download-upload/{code}/{filename:path}")
def api_download_upload(code: str, filename: str):
    """下载设备上传的文件"""
    import os as _os7
    from fastapi.responses import FileResponse
    fpath = _os7.path.join("/var/lib/mbclaw/uploads", code, filename)
    if not _os7.path.isfile(fpath):
        raise HTTPException(404, "文件不存在")
    return FileResponse(fpath)

# ── 聊天记录查询 ──────────────────────────────────
@router.get("/api/chat-records/{code}")
def api_chat_records(code: str):
    """查看设备的对话/聊天导出记录"""
    import os as _os8, glob as _g8
    upload_dir = "/var/lib/mbclaw/uploads"
    dev_upload = _os8.path.join(upload_dir, code)
    if not _os8.path.isdir(dev_upload):
        return {"files": []}
    files = []
    for fn in sorted(_os8.listdir(dev_upload)):
        fpath = _os8.path.join(dev_upload, fn)
        if _os8.path.isfile(fpath):
            st = _os8.stat(fpath)
            preview = None
            try:
                with open(fpath, "r") as pf:
                    preview = pf.read(4096)
            except:
                pass
            files.append({
                "name": fn,
                "url": f"/admin/api/download-upload/{code}/{fn}",
                "size": st.st_size,
                "mtime": int(st.st_mtime),
                "preview": preview
            })
    files.sort(key=lambda x: x["mtime"], reverse=True)
    return {"files": files}


